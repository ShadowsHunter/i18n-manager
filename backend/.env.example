# Node Environment
NODE_ENV=development

# Server Port
PORT=3001

# Database Configuration
# For PostgreSQL (production):
DATABASE_URL="postgresql://username:password@localhost:5432/multilang_db?schema=public"

# For SQLite (development):
# DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# CORS Configuration
# For development, use '*' to allow all origins
# For production, specify your frontend domain:
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Rate Limiting
RATE_LIMIT_WINDOW=3600000  # 1 hour in milliseconds
RATE_LIMIT_MAX=100  # Max requests per window
