# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase credentials

# Supabase Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase Anon Key (public - for client-side use)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb3xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5NjAwMDAwMDB9.YOUR_ANON_KEY_HERE

# Supabase Service Role Key (private - for server-side use only)
# WARNING: Never commit this key to version control or use it in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb3xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5NjAwMDAwMDB9.YOUR_SERVICE_ROLE_KEY_HERE

# JWT Secret (for token verification)
JWT_SECRET=your-jwt-secret-key-min-32-chars-long

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
